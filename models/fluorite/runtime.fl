/// Protocol types for executor ↔ runtime communication
package runtime;

// --- Tool inputs ---

struct BashInput { command: String, timeout_secs: Option<u64>, workspace: Option<String> }
struct ReadFileInput { path: String, start_line: Option<u64>, end_line: Option<u64>, workspace: Option<String> }
struct WriteFileInput { path: String, content: String, workspace: Option<String> }

// Content-based find/replace. `regex` (default false) switches `find` from a
// literal string to a pattern; `replace_all` (default false) requires the match
// to be unique and errors otherwise — set it true to change every occurrence.
struct FindAndReplaceInput { path: String, find: String, replace: String, regex: Option<bool>, replace_all: Option<bool>, workspace: Option<String> }

// Positional replacement: swap the 1-based, inclusive line range for `replacement`.
struct ReplaceLinesInput { path: String, start_line: u64, end_line: u64, replacement: String, workspace: Option<String> }

struct ListFilesInput { path: String, workspace: Option<String> }
struct GlobInput { pattern: String, path: Option<String>, max_results: Option<u64>, workspace: Option<String> }
struct GrepInput { pattern: String, path: Option<String>, file_pattern: Option<String>, max_results: Option<u64>, workspace: Option<String> }

/// One variant per tool. The tag doubles as the tool name seen by the LLM.
#[type_tag = "tool"]
union ToolCall {
    Bash(BashInput),
    ReadFile(ReadFileInput),
    WriteFile(WriteFileInput),
    FindAndReplace(FindAndReplaceInput),
    ReplaceLines(ReplaceLinesInput),
    ListFiles(ListFilesInput),
    Glob(GlobInput),
    Grep(GrepInput),
}

// --- Workspace scan ---

// Parameterized so the runtime stays convention-agnostic: the client supplies the
// instruction filenames to try (in order) and the skills glob. Raw contents come
// back; the client parses frontmatter.
struct ScanRequest {
    call_id: String,
    workspace: Option<String>,
    instruction_candidates: Vec<String>,
    skills_glob: String,
    /// When true, also enumerate the shared plugin library and return its skills in
    /// `ScanResponse.shared_skills`. The client sets this only for opted-in agents.
    include_shared: bool,
}

struct ScannedFile { path: String, content: String }
struct WorkspaceScan {
    name: String,
    path: String,
    is_git_repo: bool,
    instructions: Option<ScannedFile>,
    skills: Vec<ScannedFile>,
}

/// A skill discovered in the shared plugin library. `rel_dir` is the skill's
/// directory relative to the plugins root (the `horsie_shared` workspace), so the
/// agent can read sibling resources with the filesystem tools.
struct PluginSkill {
    plugin: String,
    rel_dir: String,
    content: String,
}
struct ScanResponse {
    call_id: String,
    workspaces: Vec<WorkspaceScan>,
    shared_skills: Vec<PluginSkill>,
}

// --- SessionStart hooks ---

/// Run every installed plugin's SessionStart hook inside the sandbox and return
/// the concatenated injected context (empty when there are no hooks / no plugins).
struct SessionStartRequest { call_id: String }
struct SessionStartResponse { call_id: String, context: String }

// --- Inbound (executor → runtime) ---

struct ToolCallRequest  { call_id: String, call: ToolCall }
struct CancelCallRequest { call_id: String }

#[type_tag = "type"]
union RuntimeInboundMessage {
    ToolCall(ToolCallRequest),
    CancelCall(CancelCallRequest),
    ScanWorkspace(ScanRequest),
    SessionStart(SessionStartRequest),
}

// --- Outbound (runtime → executor) ---

struct ToolOutput { stdout: String, stderr: String, exit_code: i32 }
struct ToolError  { reason: String }

#[type_tag = "status"]
union ToolResult { Ok(ToolOutput), Err(ToolError) }

struct ToolCallResponse { call_id: String, result: ToolResult }

/// First message the runtime sends after connecting.
struct RuntimeReady { runtime_id: String }

/// Announces that the runtime is executing provision steps before Ready. The
/// executor extends its handshake deadline and expects Ready or
/// ProvisionFailed next on this connection.
struct RuntimeProvisioning { runtime_id: String }

/// Provision steps failed; the runtime exits after sending this. `message` is
/// surfaced as the create/attach failure reason.
struct RuntimeProvisionFailed { runtime_id: String, message: String }

/// All messages the runtime sends to the executor.
#[type_tag = "type"]
union RuntimeOutboundMessage {
    Ready(RuntimeReady),
    Provisioning(RuntimeProvisioning),
    ProvisionFailed(RuntimeProvisionFailed),
    ToolCallResponse(ToolCallResponse),
    ScanResult(ScanResponse),
    SessionStartResult(SessionStartResponse),
}
