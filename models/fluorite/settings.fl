/// Wire types for the server settings API: a redacted view of the
/// runtime-editable configuration, and the update inputs that replace it.
/// Secrets are never returned — provider/vendor views carry only a boolean
/// flag for a stored inline secret.
package settings;

/// One configured LLM provider, redacted for display.
struct ProviderView {
    /// Provider name — the key a model's `provider` references.
    name: String,
    /// Provider kind, e.g. "anthropic" (the only kind today).
    kind: String,
    base_url: Option<String>,
    /// True when an inline `api_key` is stored.
    has_inline_key: bool,
}

/// One configured model alias.
struct ModelView {
    /// The alias sessions select (e.g. "sonnet").
    alias: String,
    /// Name of the provider this model routes to.
    provider: String,
    /// The provider's model identifier (e.g. "claude-sonnet-4-6").
    model_id: String,
    max_tokens: Option<u32>,
}

/// A runtime vendor sessions can target. `local` is built-in and carries no
/// config; every other vendor carries a kind-tagged config block.
struct VendorView {
    name: String,
    /// Loaded and usable in the running server (configurable vendors activate on
    /// the next restart, so this can lag what is persisted).
    active: bool,
    /// Whether new sessions default to this vendor.
    is_default: bool,
    /// Kind-specific config, redacted. Absent for the built-in `local` vendor.
    config: Option<VendorConfigView>,
}

/// Redacted config for a configurable vendor, tagged by kind. Add a variant to
/// support a new vendor kind — no schema migration needed.
#[type_tag = "kind"]
union VendorConfigView {
    Velos(VelosView),
}

/// The velos remote-runtime config, redacted (no token).
struct VelosView {
    server_url: String,
    image: String,
    advertise_host: String,
    has_inline_token: bool,
    runtime_bin: String,
    workspace_root: String,
    listen: String,
    cpu: u32,
    memory_mib: u64,
    connect_timeout_secs: u64,
    /// Server HTTP port reachable from the worker network at `advertise_host`;
    /// used to build the plugin-artifact base URL runtimes fetch bundles from.
    http_port: Option<u32>,
}

/// Read-only deployment paths and version, for transparency. `config_path` is
/// the deployment config file (config.json); `database` is where the editable
/// settings above are stored — the two never overlap.
struct ServerInfo {
    config_path: String,
    database: String,
    state_dir: String,
    data_dir: String,
    plugins_dir: String,
    version: String,
}

/// Full settings snapshot — returned by `GET /api/config` and after an update.
struct SettingsView {
    providers: Vec<ProviderView>,
    models: Vec<ModelView>,
    vendors: Vec<VendorView>,
    default_vendor: String,
    info: ServerInfo,
    /// True when a persisted change (a vendor edit) needs a restart to take
    /// effect. Provider/model/default-vendor edits apply live.
    restart_required: bool,
}

// --- update inputs ---

/// A provider to persist. Replaces any provider of the same `name`.
struct ProviderInput {
    name: String,
    kind: String,
    base_url: Option<String>,
    /// New inline key. Omit to keep the existing stored key; "" to clear.
    api_key: Option<String>,
}

/// A model alias to persist.
struct ModelInput {
    alias: String,
    provider: String,
    model_id: String,
    max_tokens: Option<u32>,
}

/// A configurable vendor to persist. Replaces any vendor of the same `name`.
struct VendorInput {
    name: String,
    config: VendorConfigInput,
}

/// Kind-tagged vendor config input. Add a variant per new vendor kind.
#[type_tag = "kind"]
union VendorConfigInput {
    Velos(VelosInput),
}

/// velos config to persist. Only `server_url`, `image`, and `advertise_host`
/// are required; the rest default. `token`: omit to keep, "" to clear.
struct VelosInput {
    server_url: String,
    image: String,
    advertise_host: String,
    token: Option<String>,
    runtime_bin: Option<String>,
    workspace_root: Option<String>,
    listen: Option<String>,
    cpu: Option<u32>,
    memory_mib: Option<u64>,
    connect_timeout_secs: Option<u64>,
    /// Server HTTP port reachable from the worker network at `advertise_host`
    /// (for plugin-artifact fetches). Omit to keep the stored value.
    http_port: Option<u32>,
}

/// Replace the runtime-editable settings. Each present field fully replaces
/// that section; an omitted (null) field leaves it unchanged. `vendors` covers
/// the configurable vendors (not the built-in `local`).
struct SettingsUpdate {
    providers: Option<Vec<ProviderInput>>,
    models: Option<Vec<ModelInput>>,
    vendors: Option<Vec<VendorInput>>,
    default_vendor: Option<String>,
}
