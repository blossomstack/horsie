/// Wire types for the server settings API: a redacted view of the
/// runtime-editable configuration, and the update inputs that replace it.
/// Secrets are never returned — provider/vendor views carry only a boolean
/// flag for a stored inline secret.
package settings;

/// One configured LLM provider, redacted for display.
struct ProviderView {
    /// Provider name — the key a model's `provider` references.
    name: String,
    /// Provider kind: "anthropic" or "openai".
    kind: String,
    base_url: Option<String>,
    /// True when an inline `api_key` is stored.
    has_inline_key: bool,
}

/// One configured model alias.
struct ModelView {
    /// The alias sessions select (e.g. "sonnet").
    alias: String,
    /// Name of the provider this model routes to.
    provider: String,
    /// The provider's model identifier (e.g. "claude-sonnet-4-6").
    model_id: String,
    max_tokens: Option<u32>,
}

/// What a vendor can do with a session workspace. Announced by the vendor
/// itself; the new-session UI reads it to decide what to prompt for, instead
/// of branching on the vendor's name or kind.
struct VendorCapabilities {
    /// The vendor provisions a workspace it owns — cloning repos, installing
    /// skill bundles, running provision steps. A vendor that runs in a fixed,
    /// user-owned directory (the shared local daemon) provisions nothing.
    supports_provisioning: bool,
}

/// A runtime vendor sessions can target: DB-configured, or daemon-registered.
/// A daemon-registered vendor (e.g. a connected shared local runtime) is
/// listed under whatever label it dialed in as, and only once it has
/// actually registered. A DB-configured vendor carries a kind-tagged config
/// block; a daemon-registered one carries none.
struct VendorView {
    name: String,
    /// Loaded and usable in the running server right now.
    active: bool,
    /// Whether new sessions default to this vendor.
    is_default: bool,
    /// Kind-specific config, redacted. Absent for a daemon-registered vendor.
    config: Option<VendorConfigView>,
    /// The last build/reconfigure failure for this vendor, if any. `None`
    /// when active or never attempted.
    error: Option<String>,
    /// Announced capabilities of the live vendor instance. `None` when the
    /// vendor is configured but not currently loaded (no instance to ask);
    /// the new-session UI only offers active vendors, so it always has a
    /// value where it matters.
    capabilities: Option<VendorCapabilities>,
}

/// Redacted config for a configurable vendor, tagged by kind. Add a variant to
/// support a new vendor kind — no schema migration needed.
#[type_tag = "kind"]
union VendorConfigView {
    Velos(VelosView),
}

/// The velos remote-runtime config, redacted (no token).
struct VelosView {
    server_url: String,
    image: String,
    /// `host:port` the runtime dials back on — the server's externally reachable
    /// HTTP endpoint. Both the reverse-dial WebSocket and plugin-artifact fetch
    /// target this one address.
    advertise_address: String,
    has_inline_token: bool,
    runtime_bin: String,
    workspace_root: String,
    cpu: u32,
    memory_mib: u64,
    connect_timeout_secs: u64,
}

/// Read-only deployment paths and version, for transparency. `config_path` is
/// the deployment config file (config.json); `database` is where the editable
/// settings above are stored — the two never overlap.
struct ServerInfo {
    config_path: String,
    database: String,
    state_dir: String,
    data_dir: String,
    plugins_dir: String,
    version: String,
}

/// Full settings snapshot — returned by `GET /api/config` and after an update.
struct SettingsView {
    providers: Vec<ProviderView>,
    models: Vec<ModelView>,
    vendors: Vec<VendorView>,
    default_vendor: String,
    info: ServerInfo,
    /// Always false: every provider/model/vendor edit now applies live (no
    /// runtime listener to rebind). Retained for wire compatibility.
    restart_required: bool,
}

// --- update inputs ---

/// A provider to persist. Replaces any provider of the same `name`.
struct ProviderInput {
    name: String,
    /// Provider kind: "anthropic" or "openai".
    kind: String,
    base_url: Option<String>,
    /// New inline key. Omit to keep the existing stored key; "" to clear.
    api_key: Option<String>,
}

/// A model alias to persist.
struct ModelInput {
    alias: String,
    provider: String,
    model_id: String,
    max_tokens: Option<u32>,
}

/// A configurable vendor to persist. Replaces any vendor of the same `name`.
struct VendorInput {
    name: String,
    config: VendorConfigInput,
}

/// Kind-tagged vendor config input. Add a variant per new vendor kind.
#[type_tag = "kind"]
union VendorConfigInput {
    Velos(VelosInput),
}

/// velos config to persist. Only `server_url`, `image`, and `advertise_address`
/// are required; the rest default. `token`: omit to keep, "" to clear.
struct VelosInput {
    server_url: String,
    image: String,
    /// `host:port` the runtime dials back on (the server's externally reachable
    /// HTTP endpoint) — serves both the reverse-dial WebSocket and artifact fetch.
    advertise_address: String,
    token: Option<String>,
    runtime_bin: Option<String>,
    workspace_root: Option<String>,
    cpu: Option<u32>,
    memory_mib: Option<u64>,
    connect_timeout_secs: Option<u64>,
}

/// Replace the runtime-editable settings. Each present field fully replaces
/// that section; an omitted (null) field leaves it unchanged. `vendors` covers
/// the configurable vendors (not the built-in `local`).
struct SettingsUpdate {
    providers: Option<Vec<ProviderInput>>,
    models: Option<Vec<ModelInput>>,
    vendors: Option<Vec<VendorInput>>,
    default_vendor: Option<String>,
}

/// The outcome of an on-demand connection check for a configurable vendor
/// (currently velos only) — reachability + token validity, checked live.
/// Never persisted; a fresh check every call.
struct VendorTestResult {
    ok: bool,
    /// The authenticated identity when `ok` (e.g. "admin", "worker:name").
    identity: Option<String>,
    error: Option<String>,
}
